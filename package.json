{
  "name": "qiniu-coding-helper",
  "version": "0.3.4",
  "description": "CLI tool for configuring AI coding assistants with Qiniu API endpoints",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coding-helper": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/locales && cp -r src/locales dist/locales",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "qiniu",
    "sufy",
    "ai",
    "coding-helper",
    "cli",
    "claude-code",
    "anthropic",
    "configuration",
    "setup",
    "llm"
  ],
  "author": "krisxia0506",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/qiniu/coding-helper.git"
  },
  "homepage": "https://github.com/qiniu/coding-helper#readme",
  "bugs": {
    "url": "https://github.com/qiniu/coding-helper/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/search": "^3.2.2",
    "@inquirer/select": "^4.2.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1",
    "terminal-link": "^5.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
